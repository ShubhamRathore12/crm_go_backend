# PostgreSQL Database (Supabase or local)
# For Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxx.supabase.co:5432/postgres
# For local: postgres://postgres:postgres@localhost:5432/crm
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crm

# Redis (optional - for caching/queues)
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=8080
JWT_SECRET=change-me-in-production
JWT_EXPIRY_SECS=86400
RUST_LOG=info,tower_http=debug
